<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elena Abril | Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #ffffff; color: #1a1a1a; }
        .chart-container { position: relative; width: 100%; max-width: 500px; margin: auto; height: 300px; }
        
        /* ESTILOS PERSONALIZADOS PARA LA TARJETA DE PERFIL */
        .profile-card {
            position: relative;
            width: 120px; /* Ancho de la foto y contenedor */
            border-radius: 12px;
            overflow: hidden; /* Corta la imagen y el overlay */
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            border: 1px border border-gray-100;
        }
        
        .profile-photo {
            width: 100%;
            height: 120px; /* Foto cuadrada */
            object-cover: cover;
        }
        
        /* Degradado oscuro en la base de la foto para que el nombre blanco sea legible */
        .profile-name-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
            color: #ffffff;
            padding: 10px 8px 6px 8px;
            text-align: center;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: -0.01em;
        }

        /* Contenedor del badge debajo de la foto */
        .badge-container {
            margin-top: 8px;
            text-align: center;
            width: 120px; /* Mismo ancho que la foto */
            transform: scale(0.65); /* Escala discreta del badge */
            transform-origin: top center;
        }
    </style>
</head>
<body class="flex flex-col min-h-screen">

    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-6 h-28 flex justify-between items-center">
            
            <div class="flex flex-col items-center gap-0">
                
                <div class="profile-card">
                    <img src="https://www.canva.com/M/MAHGIXHVa3A" alt="Elena Abril" class="profile-photo">
                    <div class="profile-name-overlay">Elena Abril</div>
                </div>
                
                <div class="badge-container">
                    <div data-iframe-width="150" data-iframe-height="270" data-share-badge-id="68f469ee-e435-4729-be0c-0d4c6a7872b6" data-share-badge-host="https://www.credly.com"></div>
                    <script type="text/javascript" async src="//cdn.credly.com/assets/utilities/embed.js"></script>
                </div>
            </div>

            <nav class="hidden md:flex space-x-6 text-sm font-medium">
                <button onclick="scrollToSection('hero')" class="hover:text-gray-500">Overview</button>
                <button onclick="scrollToSection('journey')" class="hover:text-gray-500">Experience</button>
                <button onclick="scrollToSection('future')" class="text-black border-b-2 border-black pb-1">Future Focus</button>
            </nav>
        </div>
    </header>

    <main class="flex-grow">
        <section id="hero" class="py-24 text-center bg-gray-50">
            <div class="max-w-4xl mx-auto px-4">
                <h1 class="text-5xl font-extrabold mb-6">Linguistic Precision meets Technical Resilience</h1>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-10">Merging 17 years of Software Localization with modern IT Operations analysis.</p>
                <button onclick="scrollToSection('journey')" class="bg-black text-white px-8 py-3 rounded-md font-semibold hover:bg-gray-800 transition-all">Explore Journey</button>
            </div>
        </section>

        <section id="journey" class="py-16 max-w-6xl mx-auto px-6">
            <h2 class="text-3xl font-bold mb-10 text-center">Professional Trajectory</h2>
            <div class="flex justify-center space-x-4 mb-10">
                <button onclick="updateTimeline('localization')" id="btn-loc" class="px-6 py-2 bg-black text-white rounded-full text-sm">🌐 Localization</button>
                <button onclick="updateTimeline('tech')" id="btn-tech" class="px-6 py-2 bg-gray-200 text-gray-700 rounded-full text-sm">💻 IT Operations</button>
            </div>
            <div id="timeline-box" class="bg-white border border-gray-200 p-8 rounded-xl shadow-sm min-h-[250px]">
                <h3 id="era-title" class="text-2xl font-bold mb-2"></h3>
                <p id="era-dates" class="text-gray-500 font-mono text-sm mb-4"></p>
                <ul id="era-list" class="space-y-3 text-gray-700"></ul>
            </div>
        </section>
    </main>

    <footer id="future" class="bg-black text-white py-12 text-center">
        <p class="text-sm opacity-50">Elena Abril | Interactive Profile Context Mainframe Z</p>
    </footer>

    <script>
        const eraData = {
            localization: {
                title: "Localization Specialist",
                dates: "1999 – 2016",
                points: ["Linguistic QA & Compliance", "Technical Adaptation", "Testing Lead"]
            },
            tech: {
                title: "Infra Managed Service Analyst",
                dates: "2022 – Present",
                points: ["Mainframe Monitoring (CA7/Control-M)", "Incident Management", "Accenture Operations"]
            }
        };

        function updateTimeline(eraKey) {
            const data = eraData[eraKey];
            document.getElementById('era-title').textContent = data.title;
            document.getElementById('era-dates').textContent = data.dates;
            const listEl = document.getElementById('era-list');
            listEl.innerHTML = data.points.map(p => `<li>• ${p}</li>`).join('');
            
            // Actualizar botones
            document.getElementById('btn-loc').className = eraKey === 'localization' ? 'px-6 py-2 bg-black text-white rounded-full text-sm' : 'px-6 py-2 bg-gray-200 text-gray-700 rounded-full text-sm';
            document.getElementById('btn-tech').className = eraKey === 'tech' ? 'px-6 py-2 bg-black text-white rounded-full text-sm' : 'px-6 py-2 bg-gray-200 text-gray-700 rounded-full text-sm';
        }

        function scrollToSection(id) { document.getElementById(id).scrollIntoView({ behavior: 'smooth' }); }

        document.addEventListener('DOMContentLoaded', () => {
            updateTimeline('localization');
            const ctx = document.getElementById('skillsChart');
            if(ctx) {
                new Chart(ctx, {
                    type: 'radar',
                    data: {
                        labels: ['Accuracy', 'Compliance', 'Mainframe', 'Adaptation', 'Remote', 'Tools'],
                        datasets: [{ data: [95, 85, 80, 95, 90, 85], backgroundColor: 'rgba(0,0,0,0.05)', borderColor: 'black' }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
                });
            }
        });
    </script>
</body>
</html>
